# ============================================================
# RL / ML Outputs
# ============================================================
# Ignore all content inside these dirs but keep the dirs themselves via .gitkeep
logs/*
!logs/.gitkeep
outputs/*
!outputs/.gitkeep
logs/DQN_*/
outputs/*.h5
outputs/*.png
outputs/*.json

# Trained model checkpoints
*.zip
*.pkl
*.pt
*.pth
*.ckpt

# TensorBoard event files
events.out.tfevents.*

